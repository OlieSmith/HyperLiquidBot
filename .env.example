# HyperLiquid Wallet
HYPERLIQUID_PRIVATE_KEY=0xyour_private_key_here
HYPERLIQUID_WALLET_ADDRESS=0xyour_wallet_address_here

# Network
TESTNET=false

# Trading Mode
PAPER_TRADING=true

# Risk Parameters
LEVERAGE=2
MAX_POSITIONS=10
TRAILING_STOP_PCT=2.0
MIN_VOLUME_24H=1000000

# Conviction Position Sizing (% of portfolio)
CONVICTION_LOW_PCT=2.0
CONVICTION_MEDIUM_PCT=5.0
CONVICTION_HIGH_PCT=10.0

# Strategy Weights (higher = more weight in signal aggregation)
MOMENTUM_WEIGHT=1.0
MEAN_REVERSION_WEIGHT=1.0
TREND_FOLLOWING_WEIGHT=1.0

# Scan settings
SCAN_INTERVAL=60

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Logging
LOG_LEVEL=INFO
